ONESIGNAL_APP_ID=00000000-0000-0000-0000-000000000000
ONESIGNAL_API_KEY=os_v2_app_your_private_rest_api_key

# Preferred for a single personal device. Find it in OneSignal subscriptions.
ONESIGNAL_SUBSCRIPTION_ID=your_android_subscription_id

# Alternative targeting options if you do not use ONESIGNAL_SUBSCRIPTION_ID.
ONESIGNAL_EXTERNAL_USER_ID=
ONESIGNAL_INCLUDED_SEGMENT=Subscribed Users

# Optional hardening. Set to your deployed origin, for example https://one-tap-request.vercel.app
PUBLIC_APP_ORIGIN=
